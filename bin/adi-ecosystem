#!/usr/bin/env bash
# -------------------------------------------------------------
# adi-ecosystem -- ADI Development Ecosystem CLI
#
# One command to deploy a full AI development ecosystem.
# Skills, commands, hooks, governance, auto-evolution -- all in one.
# -------------------------------------------------------------
set -euo pipefail

VERSION="2.0.0"
DATA_DIR="${HOME}/.adi-ecosystem"
ECOSYSTEM_MARKER=".adi-ecosystem-installed"

# Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'; BOLD='\033[1m'

info()  { printf "${GREEN}[ok]${NC} %s\n" "$*"; }
warn()  { printf "${YELLOW}[!!]${NC} %s\n" "$*"; }
error() { printf "${RED}[xx]${NC} %s\n" "$*" >&2; }
step()  { printf "\n${BOLD}${CYAN}>> %s${NC}\n" "$*"; }

# -- Help ------------------------------------------------------
show_help() {
  cat <<EOF
${BOLD}adi-ecosystem${NC} v${VERSION} -- AI Development Ecosystem CLI

${BOLD}USAGE:${NC}
    adi-ecosystem <command> [options]

${BOLD}COMMANDS:${NC}
    init              Deploy ecosystem to current project
    init --global     Deploy skills globally (all projects)
    init --force      Re-deploy even if already installed
    adapt             Adapt ecosystem to current project type
    enhance           Run the auto-enhance learning cycle
    status            Show ecosystem status for current project
    list              List all available skills
    remove            Remove ecosystem from current project
    uninstall         Remove ecosystem CLI and all data from system
    version           Show version

${BOLD}QUICK START:${NC}
    curl -sSL https://raw.githubusercontent.com/aditya8281/adi-ecosystem/main/install.sh | bash
    cd my-project
    adi-ecosystem init

${BOLD}EXAMPLES:${NC}
    adi-ecosystem init              # Deploy to this project
    adi-ecosystem init --global     # Make skills available everywhere
    adi-ecosystem adapt             # Re-adapt to project changes
    adi-ecosystem enhance           # Run learning cycle
    adi-ecosystem status            # Check what's deployed
    adi-ecosystem list              # Browse available skills
    adi-ecosystem remove            # Remove from current project
    adi-ecosystem uninstall         # Remove everything from system

${BOLD}WHAT GETS DEPLOYED:${NC}
    Skills (86)           .claude/skills/       autoDev-prefixed, auto-evolving
    Commands (22)         .claude/commands/     slash commands for Claude Code
    Hooks (11)            .claude/hooks/        governance quality gates
    Auto-Enhance          .claude/auto-enhance/ self-learning meta-skill
    Settings              .claude/settings.local.json
    CLAUDE.md             ./CLAUDE.md           generated project config
    Ecosystem State       .claude/ecosystem/    feedback + learning data

${BOLD}AUTO-EVOLUTION:${NC}
    Every skill, command, and hook records usage to feedback.json.
    The auto-enhance system learns from patterns and improves the ecosystem.
    Run 'adi-ecosystem enhance' to trigger a learning cycle.
EOF
}

# -- Version ---------------------------------------------------
show_version() {
  echo "adi-ecosystem v${VERSION}"
}

# -- Status ----------------------------------------------------
cmd_status() {
  local project_root
  project_root="$(pwd)"

  step "Ecosystem Status"

  if [ -f "${project_root}/${ECOSYSTEM_MARKER}" ]; then
    info "Ecosystem: installed"
    cat "${project_root}/${ECOSYSTEM_MARKER}" 2>/dev/null
  else
    warn "Ecosystem: not installed"
    echo "  Run: adi-ecosystem init"
    return
  fi

  echo ""

  # Count components
  local skills=0 commands=0 hooks=0
  [ -d "${project_root}/.claude/skills" ] && skills=$(find "${project_root}/.claude/skills" -name "SKILL.md" 2>/dev/null | wc -l)
  [ -d "${project_root}/.claude/commands" ] && commands=$(find "${project_root}/.claude/commands" -maxdepth 1 -name "*.md" 2>/dev/null | wc -l)
  [ -d "${project_root}/.claude/hooks" ] && hooks=$(find "${project_root}/.claude/hooks" -maxdepth 1 -type d 2>/dev/null | tail -n +2 | wc -l)

  printf "  %-12s %s\n" "Skills:" "${skills}"
  printf "  %-12s %s\n" "Commands:" "${commands}"
  printf "  %-12s %s\n" "Hooks:" "${hooks}"

  # Check auto-enhance
  if [ -d "${project_root}/.claude/auto-enhance" ]; then
    info "Auto-Enhance: present"
  else
    warn "Auto-Enhance: missing"
  fi

  # Check feedback data
  if [ -f "${project_root}/.claude/ecosystem/feedback.json" ]; then
    local entries
    entries=$(python3 -c "import json; d=json.load(open('${project_root}/.claude/ecosystem/feedback.json')); print(len(d.get('entries',[])))" 2>/dev/null || echo "0")
    info "Feedback entries: ${entries}"
  else
    warn "Feedback: not initialized"
  fi

  # Check settings
  if [ -f "${project_root}/.claude/settings.local.json" ]; then
    info "Settings: configured"
  else
    warn "Settings: missing"
  fi

  # Check CLAUDE.md
  if [ -f "${project_root}/CLAUDE.md" ]; then
    info "CLAUDE.md: present"
  else
    warn "CLAUDE.md: not generated (run init to create)"
  fi
}

# -- List ------------------------------------------------------
cmd_list() {
  step "Available Skills"

  if [ ! -d "${DATA_DIR}/skills" ]; then
    error "Skills not found. Run install.sh first."
    exit 1
  fi

  local count=0

  for skill_dir in "${DATA_DIR}/skills"/*/; do
    [ -d "${skill_dir}" ] || continue
    local name
    name=$(basename "${skill_dir}")
    local desc=""
    if [ -f "${skill_dir}/SKILL.md" ]; then
      desc=$(head -10 "${skill_dir}/SKILL.md" | grep -i "description:" | head -1 | sed 's/.*description: *//i' | cut -c1-70)
      [ -z "$desc" ] && desc=$(head -1 "${skill_dir}/SKILL.md" | sed 's/^#* *//')
    fi
    printf "  ${BOLD}%-40s${NC} %s\n" "${name}" "${desc}"
    count=$((count + 1))
  done

  echo ""
  info "${count} skills available"
}

# -- Remove (from project) ------------------------------------
cmd_remove() {
  local project_root
  project_root="$(pwd)"

  step "Removing Ecosystem from Project"

  if [ ! -f "${project_root}/${ECOSYSTEM_MARKER}" ]; then
    warn "No ecosystem found in this project"
    return
  fi

  echo "This will remove from this project:"
  echo "  .claude/skills/"
  echo "  .claude/commands/"
  echo "  .claude/hooks/"
  echo "  .claude/auto-enhance/"
  echo "  .claude/ecosystem/"
  echo "  .claude/settings.local.json"
  echo "  ${ECOSYSTEM_MARKER}"
  echo ""
  read -rp "Continue? [y/N] " confirm
  if [[ "${confirm}" =~ ^[Yy]$ ]]; then
    rm -rf "${project_root}/.claude/skills"
    rm -rf "${project_root}/.claude/commands"
    rm -rf "${project_root}/.claude/hooks"
    rm -rf "${project_root}/.claude/auto-enhance"
    rm -rf "${project_root}/.claude/ecosystem"
    rm -f "${project_root}/.claude/settings.local.json"
    rm -f "${project_root}/${ECOSYSTEM_MARKER}"
    info "Ecosystem removed from project"
  else
    info "Cancelled"
  fi
}

# -- Uninstall (from system) ----------------------------------
cmd_uninstall() {
  step "Uninstalling adi-ecosystem"

  echo "This will permanently remove:"
  echo "  ${HOME}/.local/bin/adi-ecosystem  (CLI)"
  echo "  ${HOME}/.adi-ecosystem/           (ecosystem data)"
  echo ""
  echo "It will NOT remove ecosystems already deployed to projects."
  echo "To remove from a project, run 'adi-ecosystem remove' in that project first."
  echo ""
  read -rp "Continue? [y/N] " confirm
  if [[ "${confirm}" =~ ^[Yy]$ ]]; then
    rm -f "${HOME}/.local/bin/adi-ecosystem"
    rm -rf "${HOME}/.adi-ecosystem"
    info "CLI removed: ${HOME}/.local/bin/adi-ecosystem"
    info "Data removed: ${HOME}/.adi-ecosystem"
    echo ""
    info "Uninstall complete."
    info "To remove from projects: cd <project> && adi-ecosystem remove"
  else
    info "Cancelled"
  fi
}

# -- Adapt -----------------------------------------------------
cmd_adapt() {
  local project_root
  project_root="$(pwd)"

  step "Adapting Ecosystem"

  if [ ! -f "${project_root}/${ECOSYSTEM_MARKER}" ]; then
    error "Ecosystem not installed. Run: adi-ecosystem init"
    exit 1
  fi

  # Detect project type
  local language="" framework="" test_cmd="" lint_cmd="" build_cmd=""

  if [ -f "package.json" ]; then
    language="javascript"
    if grep -q "next" package.json 2>/dev/null; then framework="Next.js"
    elif grep -q "react" package.json 2>/dev/null; then framework="React"
    elif grep -q "vue" package.json 2>/dev/null; then framework="Vue"
    elif grep -q "express\|fastify\|hono" package.json 2>/dev/null; then framework="Node.js API"
    else framework="Node.js"; fi
    test_cmd="npm test"; lint_cmd="npm run lint"; build_cmd="npm run build"
  fi

  if [ -f "requirements.txt" ] || [ -f "pyproject.toml" ] || [ -f "setup.py" ]; then
    language="python"
    if grep -q "fastapi" requirements.txt pyproject.toml 2>/dev/null; then framework="FastAPI"
    elif grep -q "django" requirements.txt pyproject.toml 2>/dev/null; then framework="Django"
    elif grep -q "flask" requirements.txt pyproject.toml 2>/dev/null; then framework="Flask"
    else framework="Python"; fi
    test_cmd="pytest"; lint_cmd="ruff check ."
  fi

  if [ -f "Cargo.toml" ]; then
    language="rust"; framework="Rust"
    test_cmd="cargo test"; lint_cmd="cargo clippy"; build_cmd="cargo build"
  fi

  if [ -f "go.mod" ]; then
    language="go"; framework="Go"
    test_cmd="go test ./..."; lint_cmd="golangci-lint run"; build_cmd="go build ./..."
  fi

  info "Detected: ${language:-unknown} / ${framework:-unknown}"

  # Update CLAUDE.md with project-specific info
  if [ -f "${project_root}/CLAUDE.md" ]; then
    sed -i "s|Language:.*|Language: ${language:-unknown}|" "${project_root}/CLAUDE.md" 2>/dev/null || true
    sed -i "s|Framework:.*|Framework: ${framework:-unknown}|" "${project_root}/CLAUDE.md" 2>/dev/null || true
    sed -i "s|Test Runner:.*|Test Runner: ${test_cmd:-N/A}|" "${project_root}/CLAUDE.md" 2>/dev/null || true
    sed -i "s|Linter:.*|Linter: ${lint_cmd:-N/A}|" "${project_root}/CLAUDE.md" 2>/dev/null || true
    sed -i "s|Build:.*|Build: ${build_cmd:-N/A}|" "${project_root}/CLAUDE.md" 2>/dev/null || true
    info "CLAUDE.md updated"
  fi

  # Re-deploy settings if available
  if [ -f "${DATA_DIR}/settings.json" ]; then
    cp "${DATA_DIR}/settings.json" "${project_root}/.claude/settings.local.json"
    info "Settings refreshed"
  fi

  # Ensure auto-enhance is deployed
  if [ -d "${DATA_DIR}/auto-enhance" ]; then
    mkdir -p "${project_root}/.claude/auto-enhance"
    cp -r "${DATA_DIR}/auto-enhance/"* "${project_root}/.claude/auto-enhance/" 2>/dev/null || true
    info "Auto-enhance synced"
  fi

  info "Adaptation complete"
}

# -- Enhance (learning cycle) ---------------------------------
cmd_enhance() {
  local project_root
  project_root="$(pwd)"

  step "Auto-Enhance Learning Cycle"

  if [ ! -f "${project_root}/${ECOSYSTEM_MARKER}" ]; then
    error "Ecosystem not installed. Run: adi-ecosystem init"
    exit 1
  fi

  if [ ! -f "${project_root}/.claude/auto-enhance/learn.sh" ]; then
    error "learn.sh not found. Run: adi-ecosystem init"
    exit 1
  fi

  cd "${project_root}"
  bash .claude/auto-enhance/learn.sh --update-skills 2>&1

  info "Enhancement complete"
}

# -- Init (Global) ---------------------------------------------
cmd_init_global() {
  step "Global Installation"

  if [ ! -d "${DATA_DIR}/skills" ]; then
    error "Ecosystem data not found at ${DATA_DIR}"
    error "Run install.sh first."
    exit 1
  fi

  local global_skills="${HOME}/.claude/skills"
  local global_commands="${HOME}/.claude/commands"

  mkdir -p "${global_skills}"
  mkdir -p "${global_commands}"

  # Copy skills globally
  local count=0
  for skill_dir in "${DATA_DIR}/skills"/*/; do
    [ -d "${skill_dir}" ] || continue
    cp -r "${skill_dir}" "${global_skills}/"
    count=$((count + 1))
  done
  info "Installed ${count} skills globally -> ${global_skills}"

  # Copy commands globally
  cp "${DATA_DIR}/commands/"*.md "${global_commands}/" 2>/dev/null || true
  info "Installed commands globally -> ${global_commands}"

  echo ""
  info "Global installation complete"
  info "Skills available in ALL projects via Claude Code"
  echo ""
  info "For per-project hooks/settings: run 'adi-ecosystem init' in each project"
}

# -- Init (Project) --------------------------------------------
cmd_init() {
  local project_root
  project_root="$(pwd)"
  local force=false

  for arg in "$@"; do
    [ "$arg" = "--force" ] && force=true
  done

  step "Deploying ADI Ecosystem"

  if [ ! -d "${DATA_DIR}" ]; then
    error "Ecosystem data not found at ${DATA_DIR}"
    error "Run install.sh first."
    exit 1
  fi

  if [ -f "${project_root}/${ECOSYSTEM_MARKER}" ] && [ "$force" = false ]; then
    warn "Ecosystem already installed in this project"
    read -rp "Re-deploy? [y/N] " confirm
    if [[ ! "${confirm}" =~ ^[Yy]$ ]]; then
      info "Use 'adi-ecosystem remove' first, then re-init"
      return
    fi
  fi

  # Detect project type
  step "Detecting Project"

  local project_type="unknown"
  local test_cmd="" lint_cmd="" build_cmd="" framework="" language=""

  if [ -f "package.json" ]; then
    language="javascript"
    if grep -q "next" package.json 2>/dev/null; then framework="Next.js"; project_type="nextjs"
    elif grep -q "react" package.json 2>/dev/null; then framework="React"; project_type="react"
    elif grep -q "vue" package.json 2>/dev/null; then framework="Vue"; project_type="vue"
    elif grep -q "express\|fastify\|hono" package.json 2>/dev/null; then framework="Node.js API"; project_type="nodeapi"
    else framework="Node.js"; project_type="node"; fi
    test_cmd="npm test"; lint_cmd="npm run lint"; build_cmd="npm run build"
  fi

  if [ -f "requirements.txt" ] || [ -f "pyproject.toml" ] || [ -f "setup.py" ]; then
    language="python"
    if grep -q "fastapi" requirements.txt pyproject.toml 2>/dev/null; then framework="FastAPI"; project_type="fastapi"
    elif grep -q "django" requirements.txt pyproject.toml 2>/dev/null; then framework="Django"; project_type="django"
    elif grep -q "flask" requirements.txt pyproject.toml 2>/dev/null; then framework="Flask"; project_type="flask"
    else framework="Python"; project_type="python"; fi
    test_cmd="pytest"; lint_cmd="ruff check ."
  fi

  if [ -f "Cargo.toml" ]; then
    language="rust"; framework="Rust"; project_type="rust"
    test_cmd="cargo test"; lint_cmd="cargo clippy"; build_cmd="cargo build"
  fi

  if [ -f "go.mod" ]; then
    language="go"; framework="Go"; project_type="go"
    test_cmd="go test ./..."; lint_cmd="golangci-lint run"; build_cmd="go build ./..."
  fi

  if { [ -f "package.json" ] && [ -f "requirements.txt" ]; } || [ -f "pyproject.toml" ]; then
    project_type="fullstack"; framework="Full-stack"
  fi

  local makefile=""
  [ -f "Makefile" ] && makefile="Makefile"
  [ -f "justfile" ] && makefile="justfile"

  info "Language:   ${language:-unknown}"
  info "Framework:  ${framework:-unknown}"
  info "Type:       ${project_type}"
  [ -n "$makefile" ] && info "Build file: ${makefile}"
  [ -n "$test_cmd" ] && info "Test:       ${test_cmd}"
  [ -n "$lint_cmd" ] && info "Lint:       ${lint_cmd}"
  [ -n "$build_cmd" ] && info "Build:      ${build_cmd}"

  # Create .claude directories
  step "Creating Structure"

  mkdir -p "${project_root}/.claude/skills"
  mkdir -p "${project_root}/.claude/commands"
  mkdir -p "${project_root}/.claude/hooks/shared"
  mkdir -p "${project_root}/.claude/auto-enhance"
  mkdir -p "${project_root}/.claude/ecosystem"

  info ".claude/ directory structure created"

  # Deploy skills
  step "Deploying Skills"

  local skill_count=0
  for skill_dir in "${DATA_DIR}/skills"/*/; do
    [ -d "${skill_dir}" ] || continue
    cp -r "${skill_dir}" "${project_root}/.claude/skills/"
    skill_count=$((skill_count + 1))
  done
  info "${skill_count} skills deployed"

  # Deploy commands
  step "Deploying Commands"

  cp "${DATA_DIR}/commands/"*.md "${project_root}/.claude/commands/" 2>/dev/null || true
  local cmd_count
  cmd_count=$(find "${project_root}/.claude/commands" -maxdepth 1 -name "*.md" 2>/dev/null | wc -l)
  info "${cmd_count} commands deployed"

  # Deploy hooks
  step "Deploying Hooks"

  cp -r "${DATA_DIR}/hooks/"* "${project_root}/.claude/hooks/" 2>/dev/null || true
  local hook_count
  hook_count=$(find "${project_root}/.claude/hooks" -maxdepth 1 -type d 2>/dev/null | tail -n +2 | wc -l)
  info "${hook_count} hooks deployed"

  # Deploy auto-enhance
  step "Deploying Auto-Enhance"

  if [ -d "${DATA_DIR}/auto-enhance" ]; then
    cp -r "${DATA_DIR}/auto-enhance/"* "${project_root}/.claude/auto-enhance/" 2>/dev/null || true
    info "Auto-enhance deployed"
  fi

  # Deploy settings
  step "Configuring Settings"

  if [ -f "${DATA_DIR}/settings.json" ]; then
    cp "${DATA_DIR}/settings.json" "${project_root}/.claude/settings.local.json"
    info "Settings configured"
  fi

  # Initialize ecosystem state
  step "Initializing Ecosystem State"

  if [ ! -f "${project_root}/.claude/ecosystem/feedback.json" ]; then
    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    cat > "${project_root}/.claude/ecosystem/feedback.json" <<FEEDBACK
{"entries":[],"initialized":"${timestamp}","skills_used":{},"hooks_run":{},"commands_run":{}}
FEEDBACK
    info "Feedback state initialized"
  else
    info "Feedback state already exists"
  fi

  # Generate CLAUDE.md
  step "Generating CLAUDE.md"

  if [ ! -f "${project_root}/CLAUDE.md" ]; then
    local project_name
    project_name=$(basename "${project_root}")

    local description=""
    if [ -f "${project_root}/README.md" ]; then
      description=$(head -20 "${project_root}/README.md" | grep -v "^#" | grep -v "^$" | head -3 | tr '\n' ' ')
      [ -z "$description" ] && description="A ${framework:-unknown} project"
    else
      description="A ${framework:-unknown} project"
    fi

    cat > "${project_root}/CLAUDE.md" <<CLAUDEMD
# CLAUDE.md -- ${project_name}

## Project

${description}

## Tech Stack

- **Language:** ${language:-unknown}
- **Framework:** ${framework:-unknown}
- **Test Runner:** ${test_cmd:-N/A}
- **Linter:** ${lint_cmd:-N/A}
- **Build:** ${build_cmd:-N/A}

## ADI Ecosystem

This project has the ADI development ecosystem installed.

### Slash Commands (22)

| Command | Purpose |
|---------|---------|
| \`/project:start\` | Session launcher with health checks |
| \`/project:cortex\` | Full autonomous development iteration |
| \`/project:update\` | Project evolution and planning |
| \`/project:design\` | Full frontend rebuild |
| \`/project:adapt\` | Adapt ecosystem to project |
| \`/project:auto-enhance\` | Learning cycle - enhance skills |
| \`/project:refactor\` | Systematic refactoring |
| \`/project:debug\` | Systematic debugging |
| \`/project:test\` | Test generation and management |
| \`/project:deploy\` | Deployment readiness |
| \`/project:document\` | Documentation generation |
| \`/project:status\` | Project status dashboard |
| \`/project:audit\` | Codebase audit |
| \`/project:verify\` | Verification suite |
| \`/project:reflect\` | Reflection framework |
| \`/project:health\` | Repository health check |
| \`/project:architecture\` | Architecture alignment |
| \`/project:ideas\` | Innovation discovery |
| \`/project:improve\` | Ecosystem self-improvement |
| \`/project:feature-gap\` | Roadmap gap analysis |
| \`/project:prompt\` | Generate structured prompts |
| \`/project:release\` | Release readiness check |

### Skills (86 autoDev-prefixed)

All skills use the autoDev- prefix for namespace isolation.
Invoke via Skill tool: \`Skill("autoDev-brainstorming")\`

### Hooks (11 governance)

Quality gates run automatically on code changes:
- Code quality checks
- Architecture compliance
- Documentation consistency
- Skill discovery
- Completion gate (pre-merge)
- UI review

### Auto-Enhance

The ecosystem learns from every iteration:
- Tracks skill usage patterns
- Enhances skill descriptions based on success
- Adapts hooks to project type
- Prunes unused patterns

### Workflow

\`\`\`
Branch -> Adapt -> Brainstorm -> Plan -> Implement -> Test -> Validate -> Review -> Reflect -> Merge
\`\`\`

Start with \`/project:start\` or \`/project:cortex\` for implementation tasks.
CLAUDEMD
    info "CLAUDE.md generated"
  else
    if ! grep -q "ADI Ecosystem" "${project_root}/CLAUDE.md" 2>/dev/null; then
      cat >> "${project_root}/CLAUDE.md" <<'CLAUDEMD'

## ADI Ecosystem

This project has the ADI development ecosystem installed.

### Key Commands
- `/project:start` -- Session launcher
- `/project:cortex` -- Implementation workflow
- `/project:adapt` -- Adapt to project type
- `/project:auto-enhance` -- Learning cycle

### Skills (86 autoDev-prefixed)
All skills use the autoDev- prefix. Invoke via Skill tool.

### Workflow
Adapt -> Brainstorm -> Plan -> Implement -> Test -> Validate -> Review -> Reflect -> Merge
CLAUDEMD
      info "Ecosystem section added to existing CLAUDE.md"
    else
      info "CLAUDE.md already has ecosystem section"
    fi
  fi

  # Write ecosystem marker
  step "Finalizing"

  local timestamp
  timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  cat > "${project_root}/${ECOSYSTEM_MARKER}" <<MARKER
# ADI Ecosystem -- Installed
# Timestamp: ${timestamp}
# Project Type: ${project_type}
# Framework: ${framework}
# Language: ${language}
# Skills: ${skill_count}
# Commands: ${cmd_count}
# Hooks: ${hook_count}
# Version: ${VERSION}
MARKER

  info "Ecosystem marker written"

  # -- Summary --------------------------------------------------
  echo ""
  printf "${BOLD}${GREEN}==============================================${NC}\n"
  printf "${BOLD}${GREEN}  ADI Ecosystem Deployed Successfully${NC}\n"
  printf "${BOLD}${GREEN}==============================================${NC}\n"
  echo ""
  printf "  %-14s %s\n" "Project:" "${project_root}"
  printf "  %-14s %s\n" "Type:" "${framework:-unknown}"
  printf "  %-14s %s\n" "Skills:" "${skill_count}"
  printf "  %-14s %s\n" "Commands:" "${cmd_count}"
  printf "  %-14s %s\n" "Hooks:" "${hook_count}"
  echo ""
  info "Next steps:"
  echo "  1. Start Claude Code in this project"
  echo "  2. Run /project:start to initialize a session"
  echo "  3. Run /project:cortex for implementation tasks"
  echo ""
  info "To deploy globally: adi-ecosystem init --global"
  info "To re-adapt:        adi-ecosystem adapt"
  info "To enhance:         adi-ecosystem enhance"
  info "To remove:          adi-ecosystem remove"
  echo ""
}

# -- Main ------------------------------------------------------
main() {
  case "${1:-}" in
    init)
      if [ "${2:-}" = "--global" ]; then
        cmd_init_global
      else
        cmd_init "$@"
      fi
      ;;
    adapt)
      cmd_adapt
      ;;
    enhance)
      cmd_enhance
      ;;
    status)
      cmd_status
      ;;
    remove)
      cmd_remove
      ;;
    uninstall)
      cmd_uninstall
      ;;
    list)
      cmd_list
      ;;
    version|--version|-v)
      show_version
      ;;
    help|--help|-h|"")
      show_help
      ;;
    *)
      show_help
      exit 1
      ;;
  esac
}

main "$@"
