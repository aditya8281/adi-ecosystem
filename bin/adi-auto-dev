#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
# adi-auto-dev — ADI Development Ecosystem CLI
#
# Deploys a full AI development ecosystem into any project.
# Skills, commands, hooks, governance — all in one init.
# ─────────────────────────────────────────────────────────────
set -euo pipefail

VERSION="1.0.0"
DATA_DIR="${HOME}/.adi-ecosystem"
ECOSYSTEM_MARKER=".adi-ecosystem-installed"

# Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'; BOLD='\033[1m'

info()  { printf "${GREEN}✓${NC} %s\n" "$*"; }
warn()  { printf "${YELLOW}⚠${NC} %s\n" "$*"; }
error() { printf "${RED}✗${NC} %s\n" "$*" >&2; }
step()  { printf "\n${BOLD}${CYAN}▸ %s${NC}\n" "$*"; }

# ── Help ──────────────────────────────────────────────────────
show_help() {
  cat <<EOF
${BOLD}adi-auto-dev${NC} v${VERSION} — AI Development Ecosystem CLI

${BOLD}USAGE:${NC}
    adi-auto-dev <command> [options]

${BOLD}COMMANDS:${NC}
    init            Deploy ecosystem to current project
    init --global   Deploy skills globally (all projects)
    status          Show ecosystem status for current project
    remove          Remove ecosystem from current project
    list            List all available skills
    version         Show version

${BOLD}EXAMPLES:${NC}
    cd my-project
    adi-auto-dev init              # Deploy to this project
    adi-auto-dev init --global     # Make skills available everywhere
    adi-auto-dev status            # Check what's deployed
    adi-auto-dev list              # Browse available skills

${BOLD}WHAT GETS DEPLOYED:${NC}
    • 86 skills (.claude/skills/)
    • 15 slash commands (.claude/commands/project/)
    • 13 governance hooks (.claude/hooks/)
    • Settings with permissions (.claude/settings.local.json)
    • CLAUDE.md generation
    • Ecosystem feedback state (.claude/ecosystem/)

${BOLD}AFTER INIT:${NC}
    Open Claude Code → ecosystem active → /project:start to begin
EOF
}

# ── Version ───────────────────────────────────────────────────
show_version() {
  echo "adi-auto-dev v${VERSION}"
}

# ── Status ────────────────────────────────────────────────────
cmd_status() {
  local project_root
  project_root="$(pwd)"

  step "Ecosystem Status"

  if [ -f "${project_root}/${ECOSYSTEM_MARKER}" ]; then
    info "Ecosystem: ${GREEN}installed${NC}"
    cat "${project_root}/${ECOSYSTEM_MARKER}" 2>/dev/null
  else
    warn "Ecosystem: ${YELLOW}not installed${NC}"
    echo "  Run: adi-auto-dev init"
    return
  fi

  echo ""

  # Count components
  local skills=0 commands=0 hooks=0
  [ -d "${project_root}/.claude/skills" ] && skills=$(find "${project_root}/.claude/skills" -name "SKILL.md" 2>/dev/null | wc -l)
  [ -d "${project_root}/.claude/commands" ] && commands=$(find "${project_root}/.claude/commands" -name "*.md" 2>/dev/null | wc -l)
  [ -d "${project_root}/.claude/hooks" ] && hooks=$(find "${project_root}/.claude/hooks" -maxdepth 1 -type d 2>/dev/null | tail -n +2 | wc -l)

  printf "  %-12s %s\n" "Skills:" "${skills}"
  printf "  %-12s %s\n" "Commands:" "${commands}"
  printf "  %-12s %s\n" "Hooks:" "${hooks}"

  # Check settings
  if [ -f "${project_root}/.claude/settings.local.json" ]; then
    info "Settings: configured"
  else
    warn "Settings: missing"
  fi

  # Check CLAUDE.md
  if [ -f "${project_root}/CLAUDE.md" ]; then
    info "CLAUDE.md: present"
  else
    warn "CLAUDE.md: not generated (run init to create)"
  fi
}

# ── List ──────────────────────────────────────────────────────
cmd_list() {
  step "Available Skills"

  if [ ! -d "${DATA_DIR}/skills" ]; then
    error "Skills not found. Run install.sh first."
    exit 1
  fi

  local categories=("cortex" "caveman" "brainstorming" "writing" "ui" "code" "test" "deploy" "arch")
  local count=0

  for skill_dir in "${DATA_DIR}/skills"/*/; do
    [ -d "${skill_dir}" ] || continue
    local name
    name=$(basename "${skill_dir}")
    local desc=""
    if [ -f "${skill_dir}/SKILL.md" ]; then
      desc=$(head -5 "${skill_dir}/SKILL.md" | grep -i "description:" | head -1 | sed 's/.*description: *//i' | cut -c1-60)
      [ -z "$desc" ] && desc=$(head -1 "${skill_dir}/SKILL.md" | sed 's/^#* *//')
    fi
    printf "  ${BOLD}%-35s${NC} %s\n" "${name}" "${desc}"
    count=$((count + 1))
  done

  echo ""
  info "${count} skills available"
}

# ── Remove ────────────────────────────────────────────────────
cmd_remove() {
  local project_root
  project_root="$(pwd)"

  step "Removing Ecosystem"

  if [ ! -f "${project_root}/${ECOSYSTEM_MARKER}" ]; then
    warn "No ecosystem found in this project"
    return
  fi

  echo "This will remove:"
  echo "  • .claude/skills/"
  echo "  • .claude/commands/project/"
  echo "  • .claude/hooks/"
  echo "  • .claude/ecosystem/"
  echo "  • .claude/settings.local.json"
  echo "  • ${ECOSYSTEM_MARKER}"
  echo ""
  read -rp "Continue? [y/N] " confirm
  if [[ "${confirm}" =~ ^[Yy]$ ]]; then
    rm -rf "${project_root}/.claude/skills"
    rm -rf "${project_root}/.claude/commands/project"
    rm -rf "${project_root}/.claude/hooks"
    rm -rf "${project_root}/.claude/ecosystem"
    rm -f "${project_root}/.claude/settings.local.json"
    rm -f "${project_root}/${ECOSYSTEM_MARKER}"
    info "Ecosystem removed"
  else
    info "Cancelled"
  fi
}

# ── Init (Global) ─────────────────────────────────────────────
cmd_init_global() {
  step "Global Installation"

  if [ ! -d "${DATA_DIR}/skills" ]; then
    error "Ecosystem data not found at ${DATA_DIR}"
    error "Run install.sh from the adi-ecosystem folder first."
    exit 1
  fi

  local global_skills="${HOME}/.claude/skills"
  local global_commands="${HOME}/.claude/commands"

  mkdir -p "${global_skills}"
  mkdir -p "${global_commands}/project"

  # Copy skills globally
  local count=0
  for skill_dir in "${DATA_DIR}/skills"/*/; do
    [ -d "${skill_dir}" ] || continue
    local name
    name=$(basename "${skill_dir}")
    cp -r "${skill_dir}" "${global_skills}/"
    count=$((count + 1))
  done
  info "Installed ${count} skills globally → ${global_skills}"

  # Copy commands globally
  cp "${DATA_DIR}/commands/"*.md "${global_commands}/" 2>/dev/null || true
  cp "${DATA_DIR}/commands/project/"*.md "${global_commands}/project/" 2>/dev/null || true
  info "Installed commands globally → ${global_commands}"

  echo ""
  info "✅ Global installation complete"
  info "Skills available in ALL projects via Claude Code"
  echo ""
  info "For per-project hooks/settings: run 'adi-auto-dev init' in each project"
}

# ── Init (Project) ────────────────────────────────────────────
cmd_init() {
  local project_root
  project_root="$(pwd)"

  step "Deploying ADI Ecosystem"

  # Check ecosystem data exists
  if [ ! -d "${DATA_DIR}" ]; then
    error "Ecosystem data not found at ${DATA_DIR}"
    error "Run install.sh from the adi-ecosystem folder first."
    exit 1
  fi

  # Check if already installed
  if [ -f "${project_root}/${ECOSYSTEM_MARKER}" ]; then
    warn "Ecosystem already installed in this project"
    read -rp "Re-deploy? [y/N] " confirm
    if [[ ! "${confirm}" =~ ^[Yy]$ ]]; then
      info "Use 'adi-auto-dev remove' first, then re-init"
      return
    fi
  fi

  # Detect project type
  step "Detecting Project"

  local project_type="unknown"
  local test_cmd=""
  local lint_cmd=""
  local build_cmd=""
  local framework=""
  local language=""

  # Language + framework detection
  if [ -f "package.json" ]; then
    language="javascript"
    if grep -q "next" package.json 2>/dev/null; then
      framework="Next.js"
      project_type="nextjs"
    elif grep -q "react" package.json 2>/dev/null; then
      framework="React"
      project_type="react"
    elif grep -q "vue" package.json 2>/dev/null; then
      framework="Vue"
      project_type="vue"
    elif grep -q "express\|fastify\|hono" package.json 2>/dev/null; then
      framework="Node.js API"
      project_type="nodeapi"
    else
      framework="Node.js"
      project_type="node"
    fi
    test_cmd="npm test"
    lint_cmd="npm run lint"
    build_cmd="npm run build"
  fi

  if [ -f "requirements.txt" ] || [ -f "pyproject.toml" ] || [ -f "setup.py" ]; then
    language="python"
    if grep -q "fastapi" requirements.txt pyproject.toml 2>/dev/null; then
      framework="FastAPI"
      project_type="fastapi"
    elif grep -q "django" requirements.txt pyproject.toml 2>/dev/null; then
      framework="Django"
      project_type="django"
    elif grep -q "flask" requirements.txt pyproject.toml 2>/dev/null; then
      framework="Flask"
      project_type="flask"
    else
      framework="Python"
      project_type="python"
    fi
    test_cmd="pytest"
    lint_cmd="ruff check ."
  fi

  if [ -f "Cargo.toml" ]; then
    language="rust"
    framework="Rust"
    project_type="rust"
    test_cmd="cargo test"
    lint_cmd="cargo clippy"
    build_cmd="cargo build"
  fi

  if [ -f "go.mod" ]; then
    language="go"
    framework="Go"
    project_type="go"
    test_cmd="go test ./..."
    lint_cmd="golangci-lint run"
    build_cmd="go build ./..."
  fi

  # Check for mixed
  if [ -f "package.json" ] && [ -f "requirements.txt" ] || [ -f "pyproject.toml" ]; then
    project_type="fullstack"
    framework="Full-stack"
  fi

  # Check for Makefile
  local makefile=""
  if [ -f "Makefile" ]; then
    makefile="Makefile"
  elif [ -f "justfile" ]; then
    makefile="justfile"
  fi

  info "Language:   ${language:-unknown}"
  info "Framework:  ${framework:-unknown}"
  info "Type:       ${project_type}"
  [ -n "$makefile" ] && info "Build file: ${makefile}"
  [ -n "$test_cmd" ] && info "Test:       ${test_cmd}"
  [ -n "$lint_cmd" ] && info "Lint:       ${lint_cmd}"
  [ -n "$build_cmd" ] && info "Build:      ${build_cmd}"

  # Create .claude directories
  step "Creating Structure"

  mkdir -p "${project_root}/.claude/skills"
  mkdir -p "${project_root}/.claude/commands/project"
  mkdir -p "${project_root}/.claude/hooks/shared"
  mkdir -p "${project_root}/.claude/ecosystem"

  info ".claude/ directory structure created"

  # Deploy skills
  step "Deploying Skills"

  local skill_count=0
  for skill_dir in "${DATA_DIR}/skills"/*/; do
    [ -d "${skill_dir}" ] || continue
    cp -r "${skill_dir}" "${project_root}/.claude/skills/"
    skill_count=$((skill_count + 1))
  done
  info "${skill_count} skills deployed"

  # Deploy commands
  step "Deploying Commands"

  cp "${DATA_DIR}/commands/"*.md "${project_root}/.claude/commands/" 2>/dev/null || true
  cp "${DATA_DIR}/commands/project/"*.md "${project_root}/.claude/commands/project/" 2>/dev/null || true
  local cmd_count
  cmd_count=$(find "${project_root}/.claude/commands" -name "*.md" 2>/dev/null | wc -l)
  info "${cmd_count} commands deployed"

  # Deploy hooks
  step "Deploying Hooks"

  cp -r "${DATA_DIR}/hooks/"* "${project_root}/.claude/hooks/" 2>/dev/null || true
  local hook_count
  hook_count=$(find "${project_root}/.claude/hooks" -maxdepth 1 -type d 2>/dev/null | tail -n +2 | wc -l)
  info "${hook_count} hooks deployed"

  # Deploy settings
  step "Configuring Settings"

  if [ -f "${DATA_DIR}/settings.json" ]; then
    cp "${DATA_DIR}/settings.json" "${project_root}/.claude/settings.local.json"
    info "Settings configured"
  fi

  # Initialize ecosystem state
  step "Initializing Ecosystem State"

  if [ ! -f "${project_root}/.claude/ecosystem/feedback.json" ]; then
    cat > "${project_root}/.claude/ecosystem/feedback.json" <<'FEEDBACK'
{"entries":[],"initialized":"PLACEHOLDER_TIMESTAMP"}
FEEDBACK
    # Replace timestamp
    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    sed -i "s/PLACEHOLDER_TIMESTAMP/${timestamp}/" "${project_root}/.claude/ecosystem/feedback.json"
    info "Feedback state initialized"
  else
    info "Feedback state already exists"
  fi

  # Generate CLAUDE.md
  step "Generating CLAUDE.md"

  if [ ! -f "${project_root}/CLAUDE.md" ]; then
    local project_name
    project_name=$(basename "${project_root}")

    # Try to get description from README
    local description=""
    if [ -f "${project_root}/README.md" ]; then
      description=$(head -20 "${project_root}/README.md" | grep -v "^#" | grep -v "^$" | head -3 | tr '\n' ' ')
      [ -z "$description" ] && description="A ${framework:-unknown} project"
    else
      description="A ${framework:-unknown} project"
    fi

    cat > "${project_root}/CLAUDE.md" <<CLAUDEMD
# CLAUDE.md — ${project_name}

## Project

${description}

## Tech Stack

- **Language:** ${language:-unknown}
- **Framework:** ${framework:-unknown}
- **Test Runner:** ${test_cmd:-N/A}
- **Linter:** ${lint_cmd:-N/A}
- **Build:** ${build_cmd:-N/A}

## ADI Ecosystem

This project has the ADI development ecosystem installed.

### Slash Commands

| Command | Purpose |
|---------|---------|
| \`/project:start\` | Session launcher with health checks |
| \`/project:cortex\` | Implementation workflow |
| \`/project:update\` | Feature planning |
| \`/project:audit\` | Codebase audit |
| \`/project:verify\` | Verification suite |
| \`/project:reflect\` | Reflection framework |
| \`/project:health\` | Repository health check |
| \`/project:architecture\` | Architecture alignment |

### Skills (86 available)

Key skills: brainstorming, writing-plans, tdd, code-review, subagent-driven-development, design-system, ui-ux-design, api-design

### Hooks (governance)

Quality gates run automatically on code changes:
- Code quality checks
- Architecture compliance
- Documentation consistency
- Skill discovery
- Completion gate (pre-merge)

### Workflow

\`\`\`
Branch → Skill Discovery → Brainstorm → Plan → Implement → Test → Validate → Review → Reflect → Merge
\`\`\`

Every significant task follows this workflow. Start with \`/project:cortex\` for implementation tasks.
CLAUDEMD
    info "CLAUDE.md generated"
  else
    # Append ecosystem section if not present
    if ! grep -q "ADI Ecosystem" "${project_root}/CLAUDE.md" 2>/dev/null; then
      cat >> "${project_root}/CLAUDE.md" <<'CLAUDEMD'

## ADI Ecosystem

This project has the ADI development ecosystem installed.

### Key Commands
- `/project:start` — Session launcher
- `/project:cortex` — Implementation workflow
- `/project:update` — Feature planning
- `/project:audit` — Codebase audit
- `/project:verify` — Verification suite
- `/project:health` — Repository health

### Skills (86 available)
Key skills: brainstorming, writing-plans, tdd, code-review, subagent-driven-development

### Workflow
Branch → Skill Discovery → Brainstorm → Plan → Implement → Test → Validate → Review → Reflect → Merge
CLAUDEMD
      info "Ecosystem section added to existing CLAUDE.md"
    else
      info "CLAUDE.md already has ecosystem section"
    fi
  fi

  # Write ecosystem marker
  step "Finalizing"

  local timestamp
  timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  cat > "${project_root}/${ECOSYSTEM_MARKER}" <<MARKER
# ADI Ecosystem — Installed
# Timestamp: ${timestamp}
# Project Type: ${project_type}
# Framework: ${framework}
# Language: ${language}
# Skills: ${skill_count}
# Commands: ${cmd_count}
# Hooks: ${hook_count}
MARKER

  info "Ecosystem marker written"

  # ── Summary ──────────────────────────────────────────────────
  echo ""
  printf "${BOLD}${GREEN}═══════════════════════════════════════════════════${NC}\n"
  printf "${BOLD}${GREEN}  ✅  ADI Ecosystem Deployed Successfully${NC}\n"
  printf "${BOLD}${GREEN}═══════════════════════════════════════════════════${NC}\n"
  echo ""
  printf "  %-14s %s\n" "Project:" "${project_root}"
  printf "  %-14s %s\n" "Type:" "${framework:-unknown}"
  printf "  %-14s %s\n" "Skills:" "${skill_count}"
  printf "  %-14s %s\n" "Commands:" "${cmd_count}"
  printf "  %-14s %s\n" "Hooks:" "${hook_count}"
  echo ""
  info "Next steps:"
  echo "  1. Start Claude Code in this project"
  echo "  2. Run /project:start to initialize a session"
  echo "  3. Run /project:cortex for implementation tasks"
  echo ""
  info "To deploy globally: adi-auto-dev init --global"
  info "To remove:          adi-auto-dev remove"
  echo ""
}

# ── Main ──────────────────────────────────────────────────────
main() {
  case "${1:-}" in
    init)
      if [ "${2:-}" = "--global" ]; then
        cmd_init_global
      else
        cmd_init
      fi
      ;;
    status)
      cmd_status
      ;;
    remove)
      cmd_remove
      ;;
    list)
      cmd_list
      ;;
    version|--version|-v)
      show_version
      ;;
    help|--help|-h)
      show_help
      ;;
    *)
      show_help
      exit 1
      ;;
  esac
}

main "$@"
