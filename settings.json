{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Agent(*)",
      "Skill(*)",
      "WebFetch(*)",
      "NotebookEdit(*)",
      "WebSearch",
      "mcp__context7__query-docs(*)",
      "mcp__sequential-thinking__sequentialthinking(*)",
      "mcp__playwright__browser_navigate(*)",
      "mcp__playwright__browser_snapshot(*)",
      "mcp__playwright__browser_click(*)",
      "mcp__playwright__browser_type(*)",
      "mcp__playwright__browser_evaluate(*)",
      "mcp__plugin_context-mode_context-mode__ctx_execute(*)",
      "mcp__plugin_context-mode_context-mode__ctx_batch_execute(*)",
      "mcp__plugin_context-mode_context-mode__ctx_search(*)",
      "mcp__plugin_context-mode_context-mode__ctx_execute_file(*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/run_hooks.py pre-commit",
            "timeout": 30,
            "statusMessage": "Running governance gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/run_hooks.py onchange",
            "timeout": 15,
            "statusMessage": "Running quality checks"
          }
        ]
      }
    ],
    "PrePush": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/run_hooks.py pre-push",
            "timeout": 60,
            "statusMessage": "Running pre-push checks"
          }
        ]
      }
    ],
    "PreMerge": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/run_hooks.py pre-merge",
            "timeout": 120,
            "statusMessage": "Running pre-merge validation"
          }
        ]
      }
    ]
  },
  "env": {
    "ADI_ECOSYSTEM": "active",
    "APP_ENV": "development"
  }
}
